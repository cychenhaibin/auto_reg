# Docker 构建 & 推送配置
# 复制此文件为 .env.docker 并填入你的配置

# Docker Registry 地址（必填，用于推送）
# Docker Hub 示例: docker.io/yourusername
# 私有仓库示例: registry.example.com/yourproject
DOCKER_REGISTRY=

# 镜像名称（可选，默认 any-auto-register）
DOCKER_IMAGE_NAME=any-auto-register

# 自定义 Tag（可选，默认自动生成: 日期时间-git哈希）
# DOCKER_TAG=v1.0.0

# 目标平台（可选，默认 linux/amd64）
DOCKER_PLATFORM=linux/amd64

# Camoufox 版本（可选）
CAMOUFOX_VERSION=135.0.1
CAMOUFOX_RELEASE=beta.24

# Registry 登录凭据（可选，也可手动 docker login）
# DOCKER_USERNAME=your_username
# DOCKER_PASSWORD=your_password
